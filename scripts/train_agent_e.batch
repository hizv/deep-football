#!/bin/bash

#SBATCH --job-name=agent_e_lstm_shaped
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=21
#SBATCH --mem-per-cpu=4G
#SBATCH -t 12:00:00
#SBATCH --output=agent_e_lstm_shaped-%j.out
#SBATCH --mail-type=BEGIN,END,FAIL
#SBATCH --mail-user=hagarwal67@gatech.edu

source ~/miniconda3/etc/profile.d/conda.sh
module load anaconda3

cd /home/hice1/hagarwal67/bin/deep-football
conda activate soccertwos

echo "Working directory: $(pwd)"
echo "CPUs available: $(nproc)"

python agent_e_lstm_shaped/train.py \
    --timesteps 8000000 \
    --num-workers 20 \
    --num-envs-per-worker 3 \
    --lr 1e-4 \
    --gamma 0.99 \
    --gae-lambda 0.95 \
    --clip-param 0.2 \
    --entropy-coeff 0.01 \
    --local-dir agent_e_lstm_shaped/ray_results \
    --experiment-name AgentE_LSTM_GoalAwarePBRS
