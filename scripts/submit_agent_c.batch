#!/bin/bash

# Soccer Twos Agent C (MAPPO Full Stack) - SLURM Job Script for PACE
# MAPPO + compact observations + PBRS + curriculum + archived self-play snapshots
# Author: Your name
# Date: 2026-04-20

# INSTRUCTIONS:
# 1. Replace YOUR_GT_USERNAME with your actual GT username
# 2. Adjust --ntasks-per-node, --mem-per-cpu, -t as needed (longer for more timesteps)
# 3. Set --mail-user to your email for notifications
# 4. Submit with: sbatch scripts/submit_agent_c.batch
# 5. For quick validation: set --timesteps 500000 and --num-workers 4

#SBATCH --job-name=soccerstwos
#SBATCH -N1 --ntasks-per-node=24
#SBATCH --mem-per-cpu=6G
#SBATCH -t12:00:00
#SBATCH --output=logs/soccerstwos-%j.out
#SBATCH --mail-type=BEGIN,END,FAIL
#SBATCH --mail-user=nparikh44@gatech.edu

set -euo pipefail

mkdir -p logs

if [ -f "$HOME/miniconda3/etc/profile.d/conda.sh" ]; then
    source "$HOME/miniconda3/etc/profile.d/conda.sh"
else
    module load anaconda3
fi
conda activate soccertwos

cd /home/hice1/nparikh44/cs-8803-drl/deep-football

echo "=== Agent C MAPPO Full Stack Training Start ===" 
echo "Nodes: $(echo $SLURM_NODELIST | tr ',' '\n' | head -5)"
echo "GPU available: $(nvidia-smi -L 2>/dev/null || echo 'None')"
BASE_PORT=$((20000 + (SLURM_JOB_ID % 20000)))
echo "Unity base port: ${BASE_PORT}"
echo "Start time: $(date)"

# Run Agent C MAPPO training with curriculum and self-play
python train_agent_c_mappo.py \
    --timesteps 15000000 \
    --time-limit-s 0 \
    --num-workers 20 \
    --num-envs-per-worker 3 \
    --lr 5e-4 \
    --gamma 0.99 \
    --base-port ${BASE_PORT} \
    --gae-lambda 0.95 \
    --clip-param 0.2 \
    --entropy-coeff 0.01 \
    --local-dir ./ray_results \
    --experiment-name AgentC_MAPPO_LowPBRS \
    --curriculum curriculum.yaml \
    --curriculum-threshold 1.0 \
    --snapshot-threshold 0.6 \
    --snapshot-interval 10 \
    --pbrs-alpha 1.0 \
    --pbrs-beta 0.3 \
    --pbrs-scale 0.1 \
    --position-scale 20.0 \
    --velocity-scale 10.0 \
    --distance-scale 30.0 \
    --checkpoint-freq 10 \
    --keep-checkpoints-num 5 \
    --max-failures 5 \

echo "=== Agent C MAPPO Full Stack Training Complete ===" 
echo "End time: $(date)"
