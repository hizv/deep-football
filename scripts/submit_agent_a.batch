#!/bin/bash

# Soccer Twos Agent A (Baseline) - SLURM Job Script for PACE
# PPO/IPPO baseline with default observations, sparse reward
# Author: Your name
# Date: 2026-04-20

# INSTRUCTIONS:
# 1. Replace YOUR_GT_USERNAME with your actual GT username
# 2. Adjust --ntasks-per-node, --mem-per-cpu, -t as needed for your resource needs
# 3. Set --mail-user to your email for notifications
# 4. Submit with: sbatch scripts/submit_agent_a.batch

#SBATCH --job-name=AgentA_Baseline
#SBATCH -N1 --ntasks-per-node=6
#SBATCH --mem-per-cpu=8G
#SBATCH -t06:00:00
#SBATCH --gres=gpu:1
#SBATCH --output=logs/agent_a-%j.out
#SBATCH --mail-type=BEGIN,END,FAIL
#SBATCH --mail-user=YOUR_GT_USERNAME@gatech.edu

mkdir -p logs

source /home/himi/miniforge3/etc/profile.d/conda.sh
conda activate soccertwos

cd /home/himi/bin/deep-football

echo "=== Agent A Baseline Training Start ===" 
echo "Node: $(hostname)"
echo "GPU available: $(nvidia-smi -L 2>/dev/null || echo 'None')"
echo "Start time: $(date)"

# Run Agent A baseline training
/home/himi/miniforge3/envs/soccertwos/bin/python train_agent_a_baseline.py \
    --timesteps 5000000 \
    --num-workers 6 \
    --num-envs-per-worker 3 \
    --lr 3e-4 \
    --gamma 0.99 \
    --gae-lambda 0.95 \
    --clip-param 0.2 \
    --entropy-coeff 0.01 \
    --local-dir ./ray_results \
    --experiment-name AgentA_Baseline

echo "=== Agent A Baseline Training Complete ===" 
echo "End time: $(date)"
