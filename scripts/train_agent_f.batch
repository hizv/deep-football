#!/bin/bash

#SBATCH --job-name=agent_f_attention_shaped
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=21
#SBATCH --mem-per-cpu=4G
#SBATCH --gres=gpu:1
#SBATCH -t 12:00:00
#SBATCH --output=agent_f_attention_shaped-%j.out
#SBATCH --mail-type=BEGIN,END,FAIL
#SBATCH --mail-user=nparikh44@gatech.edu

if [ -f "$HOME/miniconda3/etc/profile.d/conda.sh" ]; then
    source "$HOME/miniconda3/etc/profile.d/conda.sh"
else
    module load anaconda3
fi
conda activate soccertwos

cd /home/hice1/nparikh44/cs-8803-drl/deep-football

echo "Working directory: $(pwd)"
echo "CPUs available: $(nproc)"

BASE_PORT=$(( 15000 + (SLURM_JOB_ID % 40000) ))

python agent_f_attention_shaped/train.py \
    --timesteps 15000000 \
    --num-workers 20 \
    --num-envs-per-worker 3 \
    --lr 1e-4 \
    --gamma 0.99 \
    --gae-lambda 0.95 \
    --clip-param 0.2 \
    --entropy-coeff 0.01 \
    --base-port $BASE_PORT \
    --local-dir agent_f_attention_shaped/ray_results \
    --experiment-name AgentF_Attention_GoalAwarePBRS
